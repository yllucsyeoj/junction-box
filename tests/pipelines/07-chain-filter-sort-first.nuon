{
  "_comment": "Multi-step: filter age>20, sort by age desc, take first 2",
  "nodes": [
    {"id": "src", "type": "const", "position": {"x": 0, "y": 0}, "params": {"value": "[[name age]; [Alice 35] [Bob 25] [Carol 40] [Dave 22] [Eve 18]]"}},
    {"id": "flt", "type": "filter", "position": {"x": 200, "y": 0}, "params": {"column": "age", "op": ">", "value": "20"}},
    {"id": "srt", "type": "sort", "position": {"x": 400, "y": 0}, "params": {"column": "age", "direction": "desc"}},
    {"id": "top", "type": "first", "position": {"x": 600, "y": 0}, "params": {"n": "2"}},
    {"id": "out", "type": "return", "position": {"x": 800, "y": 0}, "params": {}}
  ],
  "edges": [
    {"id": "e1", "from": "src", "from_port": "output", "to": "flt", "to_port": "input"},
    {"id": "e2", "from": "flt", "from_port": "output", "to": "srt", "to_port": "input"},
    {"id": "e3", "from": "srt", "from_port": "output", "to": "top", "to_port": "input"},
    {"id": "e4", "from": "top", "from_port": "output", "to": "out", "to_port": "input"}
  ]
}
