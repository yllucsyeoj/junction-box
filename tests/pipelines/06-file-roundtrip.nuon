{
  "_comment": "Write a value to a file with file-out, then read it back with file-in via path param",
  "nodes": [
    {"id": "data", "type": "const", "position": {"x": 0, "y": 0}, "params": {"value": "{x: 100 y: 200}"}},
    {"id": "write", "type": "file-out", "position": {"x": 200, "y": 0}, "params": {"path": "/tmp/junction-box-roundtrip.nuon", "format": "nuon"}},
    {"id": "read", "type": "file-in", "position": {"x": 400, "y": 0}, "params": {"path": "/tmp/junction-box-roundtrip.nuon"}},
    {"id": "out", "type": "return", "position": {"x": 600, "y": 0}, "params": {}}
  ],
  "edges": [
    {"id": "e1", "from": "data", "from_port": "output", "to": "write", "to_port": "input"},
    {"id": "e2", "from": "read", "from_port": "output", "to": "out", "to_port": "input"}
  ]
}
