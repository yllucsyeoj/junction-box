# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# Recommended usage (picks up .env and fixes host.docker.internal on Linux):
#   docker compose up --build
#
# Manual usage:
#   docker run --env-file .env --add-host=host.docker.internal:host-gateway \
#              -p 3001:3001 -v junction-box-data:/app/data junction-box
#
# Note: host.docker.internal resolves to the Docker host machine, needed to
# reach local LLM servers (LM Studio, Ollama). Docker Desktop on Mac/Windows
# provides this automatically; on Linux it requires --add-host or docker compose.

# ── LLM ──────────────────────────────────────────────────────────────────────
# Leave LLM_ENDPOINT unset to use Anthropic cloud (default).
# Set to an OpenAI-compatible URL for local models or OpenAI:
#   LM Studio (local):  http://host.docker.internal:1234/v1/chat/completions
#   OpenAI:             https://api.openai.com/v1/chat/completions
#LLM_ENDPOINT=

# Default model ID. The llm node's --model param overrides this when set.
# For LM Studio: use the model ID shown in the LM Studio UI (e.g. google/gemma-4-26b-a4b)
# For Anthropic: e.g. claude-haiku-4-5-20251001, claude-sonnet-4-6, claude-opus-4-6
# For OpenAI: e.g. gpt-4o, gpt-4o-mini
#LLM_MODEL=

# API key for the LLM endpoint.
# For Anthropic: set LLM_API_KEY (or ANTHROPIC_API_KEY — both work).
# For OpenAI-compatible endpoints: set LLM_API_KEY as the Bearer token.
# For LM Studio: leave unset (no auth required).
#LLM_API_KEY=
#ANTHROPIC_API_KEY=

# ── FRED ─────────────────────────────────────────────────────────────────────
# Free API key: fred.stlouisfed.org/docs/api/api_key.html
#FRED_API_KEY=

# ── BLS ──────────────────────────────────────────────────────────────────────
# Free API key: data.bls.gov/registrationEngine — 25 req/day free without key, 500/day with key
#BLS_API_KEY=

# ── HUGGING FACE ─────────────────────────────────────────────────────────────
# Optional — provides higher rate limits for the HuggingFace models search.
# Get your token at: huggingface.co/settings/tokens
#HF_TOKEN=

# ── GITHUB ───────────────────────────────────────────────────────────────────
# Optional — provides 5000 req/hr (vs 60 req/hr unauthenticated).
# Create a classic token at: github.com/settings/tokens
#GITHUB_TOKEN=

# ── POSTHOG ──────────────────────────────────────────────────────────────────
# Required by the posthog-query node. API key from PostHog project settings.
#POSTHOG_API_KEY=
#POSTHOG_PROJECT_ID=

# ── SUPABASE ─────────────────────────────────────────────────────────────────
# Required by the supabase-query node. Service role key (anon key works but
# is limited by RLS policies). Find these in Supabase project settings > API.
#SUPABASE_KEY=
#SUPABASE_PROJECT=

# ── AIRTABLE ─────────────────────────────────────────────────────────────────
# Required by the airtable-query node. Generate at: airtable.com/create/tokens
#AIRTABLE_API_KEY=

# ── NOCODB ───────────────────────────────────────────────────────────────────
# Required by the nocodb-query node. Generate token in NocoDB Settings > Tokens.
# NOCODB_HOST is just the hostname — no protocol or path prefix (e.g. app.nocodb.com, or your-self-hosted.com).
# Table IDs are globally unique in NocoDB v2, so workspace/base paths are not needed.
#NOCODB_API_KEY=
#NOCODB_HOST=
