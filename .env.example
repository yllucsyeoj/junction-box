# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# Recommended usage (picks up .env and fixes host.docker.internal on Linux):
#   docker compose up --build
#
# Manual usage:
#   docker run --env-file .env --add-host=host.docker.internal:host-gateway \
#              -p 3001:3001 -v gonude-data:/app/data gonude
#
# Note: host.docker.internal resolves to the Docker host machine, needed to
# reach local LLM servers (LM Studio, Ollama). Docker Desktop on Mac/Windows
# provides this automatically; on Linux it requires --add-host or docker compose.

# ── LLM ──────────────────────────────────────────────────────────────────────
# Leave LLM_ENDPOINT unset to use Anthropic cloud (default).
# Set to an OpenAI-compatible URL for local models or OpenAI:
#   LM Studio (local):  http://host.docker.internal:1234/v1/chat/completions
#   OpenAI:             https://api.openai.com/v1/chat/completions
#LLM_ENDPOINT=

# API key for the LLM endpoint.
# For Anthropic: set LLM_API_KEY (or ANTHROPIC_API_KEY — both work).
# For OpenAI-compatible endpoints: set LLM_API_KEY as the Bearer token.
# For LM Studio: leave unset (no auth required).
#LLM_API_KEY=
#ANTHROPIC_API_KEY=
